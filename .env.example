# Hey Robot environment template

# =============================================================================
# 1. Agent model providers
# =============================================================================
# Model selection should live in deployment YAML. Keep secrets and endpoint
# overrides here only when needed by the selected provider profiles.

# DashScope
DASHSCOPE_MODEL=qwen-vl-plus
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1


# =============================================================================
# 2. Voice channel
# =============================================================================
# Used by `channels.voice`.

ARK_API_KEY=


# =============================================================================
# 3. Feishu channel
# =============================================================================
# The deployment config reads these variables for the built-in Feishu channel.
# Fill them in if you enable `channels.feishu` in deployment YAML.

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
